{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://provej.jp/data/schema/country_profile.schema.json",
  "title": "PROVE Global Data Hub — country_profile.json v0.2（REQ-006 P1-I + REQ-010 U/V/W/X）",
  "description": "国×属性。attributes（P1-I: fatf/epa/tax_treaty/visa/mofa_risk/timezone/language/msci）+ regulation（AREAER）+ oecd_crc + nexi_category + W/X stubs。",
  "type": "object",
  "required": ["schema_version", "feed_id", "last_updated", "source", "countries"],
  "additionalProperties": true,
  "properties": {
    "schema_version": { "type": "string" },
    "feed_id": { "type": "string", "const": "country_profile" },
    "last_updated": { "type": "string" },
    "source": {
      "type": "object",
      "required": ["label"],
      "properties": {
        "label": { "type": "string" },
        "url": { "type": "string" },
        "disclaimer_ja": { "type": "string" }
      }
    },
    "meta": { "type": "object" },
    "countries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["iso2", "attributes"],
        "additionalProperties": true,
        "properties": {
          "iso2": { "type": "string", "pattern": "^[A-Z]{2}$" },
          "iso3": { "type": "string", "pattern": "^[A-Z]{3}$" },
          "name_ja": { "type": "string" },
          "name_en": { "type": "string" },
          "attributes": {
            "type": "object",
            "description": "P1-I 属性セル。各値は { value, source_ref, veritas [, year, retrieved_at] }",
            "additionalProperties": {
              "type": "object",
              "required": ["value", "source_ref", "veritas"],
              "properties": {
                "value": {
                  "type": ["string", "boolean", "number", "integer", "null"]
                },
                "source_ref": { "type": "string" },
                "veritas": { "type": "string" },
                "year": { "type": "integer" },
                "retrieved_at": { "type": "string" }
              }
            }
          },
          "regulation": {
            "type": "object",
            "required": ["year", "veritas", "flags"],
            "properties": {
              "year": { "type": "integer" },
              "veritas": { "type": "string" },
              "flags": {
                "type": "object",
                "additionalProperties": { "type": "boolean" }
              }
            }
          },
          "oecd_crc": {
            "type": "object",
            "required": ["as_of", "veritas"],
            "properties": {
              "value": { "type": ["integer", "null"], "minimum": 0, "maximum": 7 },
              "as_of": { "type": "string" }
            }
          },
          "nexi_category": {
            "type": "object",
            "required": ["value", "as_of", "veritas"],
            "properties": {
              "value": { "type": "string", "pattern": "^[A-H]$" },
              "as_of": { "type": "string" }
            }
          },
          "iia_japan_bit": { "type": "object" },
          "social_security_employer_rate_pct": { "type": "object" }
        }
      }
    }
  }
}
