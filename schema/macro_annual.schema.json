{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://provej.jp/data/schema/macro_annual.schema.json",
  "title": "PROVE Global Data Hub — timeseries/macro_annual.json v2（ロング形式）",
  "description": "指標×国×年の tidy observations。REQ-SMITH-20260712-002",
  "type": "object",
  "required": ["schema_version", "feed_id", "last_updated", "frequency", "observations"],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "type": "string", "const": "2.0.0" },
    "feed_id": { "type": "string", "const": "macro_annual" },
    "last_updated": { "type": "string", "format": "date-time" },
    "frequency": { "type": "string", "const": "annual" },
    "source": {
      "type": "object",
      "properties": {
        "label": { "type": "string" },
        "url": { "type": "string" },
        "license": { "type": "string" },
        "disclaimer_ja": { "type": "string" }
      }
    },
    "meta": {
      "type": "object",
      "properties": {
        "indicator_ids": { "type": "array", "items": { "type": "string" } },
        "iso2_list": { "type": "array", "items": { "type": "string" } },
        "year_range": {
          "type": "object",
          "properties": {
            "from": { "type": ["integer", "null"] },
            "to": { "type": ["integer", "null"] }
          }
        },
        "row_count": { "type": "integer" }
      }
    },
    "observations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["indicator_id", "iso2", "year", "value"],
        "additionalProperties": false,
        "properties": {
          "indicator_id": { "type": "string" },
          "iso2": { "type": "string", "pattern": "^[A-Z]{2}$" },
          "year": { "type": "integer" },
          "value": { "type": ["number", "null"] },
          "unit": { "type": "string" },
          "source_ref": { "type": "string" },
          "veritas": { "type": "string", "enum": ["✅", "⚠️", "🔴"] }
        }
      }
    }
  }
}
