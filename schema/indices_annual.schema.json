{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://provej.jp/data/schema/indices_annual.schema.json",
  "title": "PROVE Global Data Hub — timeseries/indices_annual.json v1（REQ-006 P1-H）",
  "type": "object",
  "required": ["schema_version", "feed_id", "last_updated", "frequency", "observations"],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "type": "string", "const": "1.0.0" },
    "feed_id": { "type": "string", "const": "indices_annual" },
    "last_updated": { "type": "string", "format": "date-time" },
    "frequency": { "type": "string", "const": "annual" },
    "source": { "type": "object" },
    "meta": { "type": "object" },
    "observations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["indicator_id", "iso2", "year", "value"],
        "properties": {
          "indicator_id": { "type": "string" },
          "iso2": { "type": "string", "pattern": "^[A-Z]{2}$" },
          "year": { "type": "integer" },
          "value": { "type": "number" },
          "unit": { "type": "string" },
          "source_ref": { "type": "string" },
          "veritas": { "type": "string", "enum": ["✅", "⚠️", "🔴"] }
        }
      }
    }
  }
}
