{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://provej.jp/data/schema/digital_share_monthly.schema.json",
  "title": "PROVE Global Data Hub — digital_share_monthly.json v0.1（REQ-010 P1-Y）",
  "description": "StatCounter 国別検索/ブラウザ/OSシェア（月次 rolling）",
  "type": "object",
  "required": ["schema_version", "feed_id", "last_updated", "source", "meta", "observations"],
  "properties": {
    "schema_version": { "type": "string" },
    "feed_id": { "type": "string", "const": "digital_share_monthly" },
    "last_updated": { "type": "string" },
    "frequency": { "type": "string", "const": "monthly" },
    "status": { "type": "string" },
    "source": { "type": "object" },
    "meta": { "type": "object" },
    "observations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["indicator_id", "iso2", "period", "value"],
        "properties": {
          "indicator_id": { "type": "string" },
          "iso2": { "type": "string" },
          "period": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}$" },
          "value": { "type": "number" },
          "unit": { "type": "string" },
          "veritas": { "type": "string" }
        }
      }
    }
  }
}
